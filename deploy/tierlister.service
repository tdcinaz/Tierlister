[Unit]
Description=Tierlister Flask App
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Tierlister
EnvironmentFile=/home/ubuntu/Tierlister/.env
ExecStart=/home/ubuntu/Tierlister/.venv/bin/gunicorn --workers 2 --bind 127.0.0.1:8000 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
